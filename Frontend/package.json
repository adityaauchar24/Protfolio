{
  "name": "aditya-auchar-portfolio",
  "description": "Modern portfolio website showcasing Aditya Auchar's frontend development skills - Deployed on Netlify",
  "version": "2.0.0",
  "type": "module",
  "author": "Aditya Auchar",
  "license": "MIT",
  "private": true,
  "homepage": "https://taupe-scone-358de8.netlify.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/YOUR_USERNAME/YOUR_REPO.git"
  },
  "keywords": [
    "portfolio",
    "react",
    "typescript",
    "vite",
    "tailwindcss",
    "frontend",
    "netlify",
    "render",
    "mongodb"
  ],
  "scripts": {
    "dev": "vite",
    "start": "vite",
    "build": "vite build --mode production",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "build:prod": "VITE_API_URL=https://protfolio-backend-8p47.onrender.com vite build --mode production",
    "build:dev": "vite build --mode development",
    "build:netlify": "VITE_API_URL=https://protfolio-backend-8p47.onrender.com NODE_ENV=production vite build --mode production",
    "build:local": "VITE_API_URL=http://localhost:4000 vite build --mode development",
    "preview:prod": "npm run build:prod && vite preview --port 4173",
    "preview:dev": "npm run build:dev && vite preview --port 4174",
    "clean": "rm -rf dist node_modules/.vite",
    "test": "echo \"No tests specified\" && exit 0",
    "type-check": "tsc --noEmit",
    "analyze": "ANALYZE=true npm run build"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.1.1",
    "@mui/material": "^7.3.6",
    "@ramonak/react-progress-bar": "^5.4.0",
    "@tailwindcss/vite": "^4.1.7",
    "framer-motion": "^11.18.2",
    "lucide-react": "^0.562.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.0",
    "react-type-animation": "^3.2.0",
    "tailwindcss": "^4.1.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "vite": "^6.3.5",
    "@typescript-eslint/eslint-plugin": "^8.25.0",
    "@typescript-eslint/parser": "^8.25.0"
  },
  "engines": {
    "node": ">=18.17.0",
    "npm": ">=9.0.0",
    "pnpm": ">=8.0.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "volta": {
    "node": "18.17.0"
  },
  "packageManager": "npm@9.6.7"
}